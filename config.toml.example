[agent]
name = "mentat"
db_path = "~/.local/share/mentat/db.sqlite"
log_level = "info"

[anthropic]
# api_key is read from ANTHROPIC_API_KEY env var or .env file
# model = "claude-sonnet-4-5"  # default

[scan]
# Directories to scan when running 'mentat bootstrap' or 'mentat scan'
# If empty, defaults to home directory (not recommended)
paths = [
  "~/Documents/ai",
  "~/Projects",
]
max_depth = 5
# exclude = ["node_modules", ".git", ".venv"]
