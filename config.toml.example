[agent]
name = "mentat"
db_path = "~/.local/share/mentat/db.sqlite"
log_level = "info"

[anthropic]
# api_key is read from ANTHROPIC_API_KEY env var or .env file

# ── Vertex AI (Google Cloud) ──────────────────────────────────────────────────
# Use instead of ANTHROPIC_API_KEY when on a gcloud-authenticated machine.
# Run: gcloud auth application-default login
# [vertex]
# project_id = "my-gcp-project"
# region = "us-east5"   # Claude-supported regions: us-east5, europe-west1

[scan]
# Directories to scan when running 'mentat bootstrap' or 'mentat scan'
# If empty, defaults to home directory (not recommended)
paths = [
  "~/Documents/ai",
  "~/Projects",
]
max_depth = 5
# exclude = ["node_modules", ".git", ".venv"]
